<Project Sdk="Dalamud.NET.Sdk/15.0.0">
  <PropertyGroup>
    <AssemblyName>XIV.fm</AssemblyName>
    <RootNamespace>XIV.fm</RootNamespace>
    <Version>0.1.4</Version>
    <!-- Dalamud.NET.Sdk injects versioned package references and is not CPM-compatible. -->
    <ManagePackageVersionsCentrally>false</ManagePackageVersionsCentrally>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <Use_Dalamud_FFXIVClientStructs>true</Use_Dalamud_FFXIVClientStructs>
    <Use_Dalamud_ImPlot>false</Use_Dalamud_ImPlot>
    <Use_Dalamud_ImGuizmo>false</Use_Dalamud_ImGuizmo>
    <Use_Dalamud_MSObjectPool>false</Use_Dalamud_MSObjectPool>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="../XIV.fm.Contracts/XIV.fm.Contracts.csproj" />
    <ProjectReference Include="../XIV.fm.Plugin.Core/XIV.fm.Plugin.Core.csproj" />
    <ProjectReference Include="../XIV.fm.Plugin.Network/XIV.fm.Plugin.Network.csproj" />
  </ItemGroup>
</Project>
