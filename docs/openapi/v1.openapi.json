        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateRelayRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Relay created.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Relay"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "409": {
            "$ref": "#/components/responses/Conflict"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "429": {
            "$ref": "#/components/responses/RateLimited"
          }
        }
      },
      "get": {
        "operationId": "listRelays",
        "summary": "List joined Custom Relays",
        "security": [
          {
            "installationBearer": []
          }
        ],
        "responses": {
          "200": {
            "description": "Joined Relays.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RelayList"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "429": {
            "$ref": "#/components/responses/RateLimited"
          }
        }
      }
    },
    "/v1/relays/{relayId}": {
      "parameters": [
        {
          "name": "relayId",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string",
            "format": "uuid"
          }
        }
      ],
      "get": {
        "operationId": "getRelay",
        "summary": "Get an authorized Relay",
        "security": [
          {
            "installationBearer": []
          }
        ],
        "responses": {
          "200": {
            "description": "Relay.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Relay"
                }
              }
            }
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "429": {
            "$ref": "#/components/responses/RateLimited"
          }
        }
      },
      "patch": {
        "operationId": "renameRelay",
        "summary": "Rename an owned Relay",
        "security": [
          {
            "installationBearer": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RenameRelayRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Renamed Relay.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Relay"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "429": {
            "$ref": "#/components/responses/RateLimited"
          }
        }
      },
      "delete": {
        "operationId": "deleteRelay",
        "summary": "Delete an owned Relay",
        "security": [
          {
            "installationBearer": []
          }
        ],
        "responses": {
          "204": {
            "description": "Relay deleted."
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "429": {
            "$ref": "#/components/responses/RateLimited"
          }
        }
      }
    },
    "/v1/relays/{relayId}/members": {
      "get": {
        "operationId": "listRelayMembers",
        "summary": "List members of an owned Relay",
        "security": [
          {
            "installationBearer": []
          }
        ],
        "parameters": [
          {
            "name": "relayId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Relay members.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RelayMemberList"
                }
              }
            }
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "429": {
            "$ref": "#/components/responses/RateLimited"
          }
        }
      }
    },
    "/v1/relays/{relayId}/members/{membershipId}": {
      "delete": {
        "operationId": "kickRelayMember",
        "summary": "Kick a member from an owned Relay",
        "description": "Removes membership and publication transactionally. The owner cannot kick themselves.",
        "security": [
          {
            "installationBearer": []
          }
        ],
        "parameters": [
          {
            "name": "relayId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          },
          {
            "name": "membershipId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Member kicked."
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "409": {
            "$ref": "#/components/responses/Conflict"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "429": {
            "$ref": "#/components/responses/RateLimited"
          }
        }
      }
    },
    "/v1/relays/{relayId}/membership": {
      "delete": {
        "operationId": "leaveRelay",
        "summary": "Leave a joined Relay",
        "description": "The current owner must delete the Relay instead.",
        "security": [
          {
            "installationBearer": []
          }
        ],
        "parameters": [
          {
            "name": "relayId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Membership removed."
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "409": {
            "$ref": "#/components/responses/Conflict"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "429": {
            "$ref": "#/components/responses/RateLimited"
          }
        }
      }
    },
    "/v1/relays/{relayId}/invitations": {
      "post": {
        "operationId": "createRelayInvitation",
        "summary": "Create a single-use Relay invitation",
        "security": [
          {
            "installationBearer": []
          }
        ],
        "parameters": [
          {
            "name": "relayId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateRelayInvitationRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Invitation created; plaintext token is returned once.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CreatedRelayInvitation"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "429": {
            "$ref": "#/components/responses/RateLimited"
          }
        }
      },
      "get": {
        "operationId": "listRelayInvitations",
        "summary": "List invitations without token secrets",
        "security": [
          {
            "installationBearer": []
          }
        ],
        "parameters": [
          {
            "name": "relayId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Relay invitations.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RelayInvitationList"
                }
              }
            }
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "429": {
            "$ref": "#/components/responses/RateLimited"
          }
        }
      }
    },
    "/v1/relays/{relayId}/invitations/{invitationId}": {
      "delete": {
        "operationId": "revokeRelayInvitation",
        "summary": "Revoke an unused invitation",
        "security": [
          {
            "installationBearer": []
          }
        ],
        "parameters": [
          {
            "name": "relayId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          },
          {
            "name": "invitationId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Invitation revoked."
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "409": {
            "$ref": "#/components/responses/Conflict"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "429": {
            "$ref": "#/components/responses/RateLimited"
          }
        }
      }
    },
    "/v1/relay-invitations/preview": {
      "post": {
        "operationId": "previewRelayInvitation",
        "summary": "Preview a secret Relay invitation",
        "security": [
          {
            "installationBearer": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RelayInvitationTokenRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Invitation preview.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RelayInvitationPreview"
                }
              }
            }
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "429": {
            "$ref": "#/components/responses/RateLimited"
          }
        }
      }
    },
    "/v1/relay-invitations/accept": {
      "post": {
        "operationId": "acceptRelayInvitation",
        "summary": "Atomically accept a single-use invitation",
        "security": [
          {
            "installationBearer": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RelayInvitationTokenRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Joined Relay.",
            "content": {
              "application/json": {
