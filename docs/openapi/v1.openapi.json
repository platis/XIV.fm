          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "409": {
            "$ref": "#/components/responses/Conflict"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "429": {
            "$ref": "#/components/responses/RateLimited"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "installationBearer": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "opaque XIV.fm installation credential",
        "description": "A revocable XIV.fm installation credential. This is not a Last.fm credential."
      }
    },
    "headers": {
      "RequestId": {
        "description": "Server-controlled request correlation identifier.",
        "schema": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        }
      },
      "RetryAfter": {
        "description": "Seconds until the request may be retried.",
        "schema": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Malformed or invalid bounded input.",
        "headers": {
          "X-Request-ID": {
            "$ref": "#/components/headers/RequestId"
          }
        },
        "content": {
          "application/problem+json": {
            "schema": {
              "$ref": "#/components/schemas/ApiError"
            }
          }
        }
      },
      "Unauthorized": {
        "description": "Missing, invalid, expired, or revoked installation credential.",
        "headers": {
          "X-Request-ID": {
            "$ref": "#/components/headers/RequestId"
          }
        },
        "content": {
          "application/problem+json": {
            "schema": {
              "$ref": "#/components/schemas/ApiError"
            }
          }
        }
      },
      "Forbidden": {
        "description": "Linked-account or Relay authorization failed.",
        "headers": {
          "X-Request-ID": {
            "$ref": "#/components/headers/RequestId"
          }
        },
        "content": {
          "application/problem+json": {
            "schema": {
              "$ref": "#/components/schemas/ApiError"
            }
          }
        }
      },
      "Conflict": {
        "description": "Installation or account state conflicts with the operation.",
        "headers": {
          "X-Request-ID": {
            "$ref": "#/components/headers/RequestId"
          }
        },
        "content": {
          "application/problem+json": {
            "schema": {
              "$ref": "#/components/schemas/ApiError"
            }
          }
        }
      },
      "RateLimited": {
        "description": "A route, account, installation, or IP quota was exceeded.",
        "headers": {
          "X-Request-ID": {
            "$ref": "#/components/headers/RequestId"
          },
          "Retry-After": {
            "$ref": "#/components/headers/RetryAfter"
          }
        },
        "content": {
          "application/problem+json": {
            "schema": {
              "$ref": "#/components/schemas/ApiError"
            }
          }
        }
      },
      "Unavailable": {
        "description": "A required server dependency is unavailable and no safe cached response can be returned.",
        "headers": {
          "X-Request-ID": {
            "$ref": "#/components/headers/RequestId"
          },
          "Retry-After": {
            "$ref": "#/components/headers/RetryAfter"
          }
        },
        "content": {
          "application/problem+json": {
            "schema": {
              "$ref": "#/components/schemas/ApiError"
            }
          }
        }
      },
      "NotFound": {
        "description": "The authorized resource was not found, or a supplied secret did not match.",
        "headers": {
          "X-Request-ID": {
            "$ref": "#/components/headers/RequestId"
          }
        },
        "content": {
          "application/problem+json": {
            "schema": {
              "$ref": "#/components/schemas/ApiError"
            }
          }
        }
      }
    },
    "schemas": {
      "StartAccountLinkResponse": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "linkSessionId",
          "authorizationUrl",
          "linkCredential",
          "expiresAt",
          "pollAfterSeconds"
        ],
        "properties": {
          "linkSessionId": {
            "type": "string",
            "format": "uuid"
          },
          "authorizationUrl": {
            "type": "string",
            "format": "uri",
            "maxLength": 4096
          },
          "linkCredential": {
            "type": "string",
            "minLength": 32,
            "maxLength": 512,
            "description": "Returned once. It becomes the installation credential only after successful ownership proof."
          },
          "expiresAt": {
            "type": "string",
            "format": "date-time"
          },
          "pollAfterSeconds": {
            "type": "integer",
            "minimum": 1,
            "maximum": 30
          }
        }
      },
      "AccountLinkStatusRequest": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "linkCredential"
        ],
        "properties": {
          "linkCredential": {
            "type": "string",
            "minLength": 32,
            "maxLength": 512
          }
        }
      },
      "AccountLinkStatusResponse": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "status",
          "expiresAt",
          "lastFmAccountName"
        ],
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "pending",
              "linked",
              "failed",
              "expired"
            ]
          },
          "expiresAt": {
            "type": "string",
            "format": "date-time"
          },
          "lastFmAccountName": {
            "type": [
              "string",
              "null"
            ],
            "minLength": 1,
            "maxLength": 128,
            "description": "Present only after verified linking."
          }
        }
      },
      "InstallationCredentialResponse": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "credential"
        ],
        "properties": {
          "credential": {
            "type": "string",
            "minLength": 32,
            "maxLength": 512,
            "description": "New opaque credential returned exactly once."
          }
        }
      },
      "SyncRequest": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "pluginVersion",
          "character",
          "location",
          "visibility"
        ],
        "properties": {
          "pluginVersion": {
            "type": "string",
            "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(?:\\.[0-9]+)?$",
            "maxLength": 32
          },
          "character": {
            "$ref": "#/components/schemas/CharacterIdentity"
          },
          "location": {
            "$ref": "#/components/schemas/LocationScope"
          },
          "visibility": {
            "$ref": "#/components/schemas/VisibilitySelection"
          },
          "knownSnapshotVersion": {
            "type": [
              "string",
              "null"
            ],
            "minLength": 1,
            "maxLength": 128,
            "description": "Opaque version copied from a prior LocationPresence result."
          }
        }
      },
      "SyncResponse": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "serverTime",
          "presenceExpiresAt",
          "nextSyncAfterSeconds",
          "ownListening",
          "locationPresence"
        ],
        "properties": {
          "serverTime": {
            "type": "string",
            "format": "date-time"
          },
          "presenceExpiresAt": {
            "type": "string",
            "format": "date-time"
          },
          "nextSyncAfterSeconds": {
            "type": "integer",
            "minimum": 5,
            "maximum": 300
          },
          "ownListening": {
            "$ref": "#/components/schemas/ListeningState"
          },
          "locationPresence": {
            "$ref": "#/components/schemas/SnapshotResult"
          }
        }
      },
      "CharacterIdentity": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "homeWorldId"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 64,
            "description": "Trimmed canonical in-game character display name."
          },
          "homeWorldId": {
            "$ref": "#/components/schemas/NonZeroUInt32"
          }
        }
      },
      "LocationScope": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "currentWorldId",
          "territoryId",
          "mapId",
          "instanceId"
        ],
        "properties": {
          "currentWorldId": {
            "$ref": "#/components/schemas/NonZeroUInt32"
          },
          "territoryId": {
            "$ref": "#/components/schemas/NonZeroUInt32"
          },
          "mapId": {
            "$ref": "#/components/schemas/NonZeroUInt32"
          },
          "instanceId": {
            "$ref": "#/components/schemas/UInt32"
          }
        },
        "description": "Typed location scope. Character coordinates are never transmitted."
      },
      "VisibilitySelection": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "mode",
          "relayIds"
        ],
        "properties": {
          "mode": {
            "type": "string",
            "enum": [
              "private",
              "public",
              "custom"
            ]
          },
          "relayIds": {
            "type": "array",
            "maxItems": 5,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "format": "uuid"
            }
          }
        },
        "description": "Private/Public require no Relay IDs. Custom requires at least one currently authorized Relay ID."
      },
      "ListeningState": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "status",
          "isStale",
          "observedAt",
          "track"
        ],
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "playing",
              "notPlaying",
              "unavailable"
            ]
          },
          "isStale": {
            "type": "boolean"
          },
          "observedAt": {
            "type": [
              "string",
              "null"
            ],
            "format": "date-time"
          },
          "track": {
            "oneOf": [
              {
                "$ref": "#/components/schemas/Track"
              },
              {
                "type": "null"
              }
            ]
          }
        },
        "description": "Playing requires a track. NotPlaying and Unavailable require a null track."
      },
      "Track": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "title",
          "artist",
          "album",
          "albumArtUrl",
          "trackUrl",
          "startedAt"
        ],
        "properties": {
          "title": {
            "type": "string",
            "minLength": 1,
            "maxLength": 512
          },
          "artist": {
            "type": "string",
            "minLength": 1,
            "maxLength": 512
          },
          "album": {
            "type": [
              "string",
              "null"
            ],
            "maxLength": 512
          },
          "albumArtUrl": {
            "type": [
              "string",
              "null"
            ],
            "format": "uri",
            "maxLength": 2048
          },
          "trackUrl": {
            "type": [
              "string",
              "null"
            ],
            "format": "uri",
            "maxLength": 2048
          },
          "startedAt": {
            "type": [
              "string",
              "null"
            ],
            "format": "date-time"
          }
        }
      },
      "PresenceEntry": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "character",
          "listening"
        ],
        "properties": {
          "character": {
            "$ref": "#/components/schemas/CharacterIdentity"
          },
          "listening": {
            "$ref": "#/components/schemas/ListeningState"
          }
        }
      },
      "PresenceSnapshot": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "location",
          "generatedAt",
          "expiresAt",
          "entries"
        ],
        "properties": {
          "location": {
            "$ref": "#/components/schemas/LocationScope"
          },
          "generatedAt": {
            "type": "string",
            "format": "date-time"
          },
          "expiresAt": {
            "type": "string",
            "format": "date-time"
          },
          "entries": {
            "type": "array",
            "maxItems": 500,
            "items": {
              "$ref": "#/components/schemas/PresenceEntry"
            }
          }
        }
      },
      "SnapshotResult": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "version",
          "snapshot"
        ],
        "properties": {
          "version": {
            "type": "string",
            "minLength": 1,
            "maxLength": 128,
            "description": "Opaque shared-snapshot version."
          },
          "snapshot": {
            "oneOf": [
              {
                "$ref": "#/components/schemas/PresenceSnapshot"
              },
              {
                "type": "null"
              }
            ],
            "description": "Null when the request's knownSnapshotVersion is still current."
          }
        }
      },
      "ApiError": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "type",
          "title",
          "status",
          "code",
          "requestId"
        ],
        "properties": {
          "type": {
            "type": "string",
            "format": "uri"
          },
          "title": {
            "type": "string",
            "minLength": 1,
            "maxLength": 256
          },
          "status": {
            "type": "integer",
            "minimum": 400,
            "maximum": 599
          },
          "code": {
            "type": "string",
            "pattern": "^[a-z0-9_]+$",
            "maxLength": 128
          },
          "requestId": {
            "type": "string",
            "minLength": 1,
            "maxLength": 128
          },
          "detail": {
            "type": [
              "string",
              "null"
            ],
            "maxLength": 2048
          },
          "instance": {
            "type": [
              "string",
              "null"
            ],
            "maxLength": 2048
          },
          "errors": {
            "oneOf": [
              {
                "type": "object",
                "additionalProperties": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "maxLength": 512
                  }
                }
              },
              {
                "type": "null"
              }
            ]
          }
        }
      },
      "UInt32": {
        "type": "integer",
        "minimum": 0,
        "maximum": 4294967295
      },
      "NonZeroUInt32": {
        "type": "integer",
        "minimum": 1,
        "maximum": 4294967295
      },
      "CreateRelayRequest": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "idempotencyKey"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 3,
            "maxLength": 48
          },
          "idempotencyKey": {
            "type": "string",
            "format": "uuid"
          }
        }
      },
      "RenameRelayRequest": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 3,
            "maxLength": 48
          }
        }
      },
      "Relay": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "relayId",
          "name",
          "isOwner",
          "memberCount",
          "createdAt",
          "updatedAt"
        ],
        "properties": {
          "relayId": {
            "type": "string",
            "format": "uuid"
          },
          "name": {
            "type": "string",
            "minLength": 3,
            "maxLength": 48
          },
          "isOwner": {
            "type": "boolean"
          },
          "memberCount": {
            "type": "integer",
            "minimum": 1,
            "maximum": 100
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "RelayList": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "relays"
        ],
        "properties": {
          "relays": {
            "type": "array",
            "maxItems": 20,
            "items": {
              "$ref": "#/components/schemas/Relay"
            }
          }
        }
      },
      "RelayMember": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "membershipId",
          "lastFmAccountName",
          "isOwner",
          "joinedAt"
        ],
        "properties": {
          "membershipId": {
            "type": "string",
            "format": "uuid"
          },
          "lastFmAccountName": {
            "type": "string",
            "minLength": 1,
            "maxLength": 128
          },
          "isOwner": {
            "type": "boolean"
          },
          "joinedAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "RelayMemberList": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "members"
        ],
        "properties": {
          "members": {
            "type": "array",
            "maxItems": 100,
            "items": {
              "$ref": "#/components/schemas/RelayMember"
            }
          }
        }
      },
      "CreateRelayInvitationRequest": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "lifetimeHours": {
            "type": [
              "integer",
              "null"
            ],
            "minimum": 1,
            "maximum": 168
          }
        }
      },
      "RelayInvitation": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "invitationId",
          "createdAt",
          "expiresAt",
          "acceptedAt"
        ],
        "properties": {
          "invitationId": {
            "type": "string",
            "format": "uuid"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "expiresAt": {
            "type": "string",
            "format": "date-time"
          },
          "acceptedAt": {
            "type": [
              "string",
              "null"
            ],
            "format": "date-time"
          }
        }
      },
      "CreatedRelayInvitation": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "invitationId",
          "token",
          "createdAt",
          "expiresAt"
        ],
        "properties": {
          "invitationId": {
            "type": "string",
            "format": "uuid"
          },
          "token": {
            "type": "string",
            "minLength": 32,
            "maxLength": 512,
            "description": "Returned exactly once and stored only as a hash."
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "expiresAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "RelayInvitationList": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "invitations"
        ],
        "properties": {
          "invitations": {
            "type": "array",
            "maxItems": 100,
            "items": {
              "$ref": "#/components/schemas/RelayInvitation"
            }
          }
        }
      },
      "RelayInvitationTokenRequest": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "token"
        ],
        "properties": {
          "token": {
            "type": "string",
            "minLength": 32,
            "maxLength": 512
          }
        }
      },
      "RelayInvitationPreview": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "relayId",
          "relayName",
          "expiresAt"
        ],
        "properties": {
          "relayId": {
            "type": "string",
            "format": "uuid"
          },
          "relayName": {
            "type": "string",
            "minLength": 3,
            "maxLength": 48
          },
          "expiresAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "AcceptRelayInvitation": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "relay"
        ],
        "properties": {
          "relay": {
            "$ref": "#/components/schemas/Relay"
          }
        }
      }
    }
  }
}
