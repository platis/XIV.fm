{
  "openapi": "3.1.0",
  "info": {
    "title": "XIV.fm API",
    "version": "1.0.0",
    "description": "Proof-gated Last.fm account linking and authenticated XIV.fm plugin synchronization. Duty-bound clients make no requests.",
    "license": {
      "name": "All rights reserved",
      "identifier": "LicenseRef-Proprietary"
    }
  },
  "servers": [
    {
      "url": "/",
      "description": "Same-origin API deployment; the production host is configured externally."
    }
  ],
  "paths": {
    "/v1/account-links": {
      "post": {
        "operationId": "startAccountLink",
        "summary": "Start Last.fm account linking",
        "description": "Creates a short-lived Last.fm web-authorization session without an inline provider call. The returned high-entropy linkCredential becomes the installation credential only after callback ownership proof succeeds.",
        "responses": {
          "201": {
            "description": "Link session created.",
            "headers": {
              "X-Request-ID": {
                "$ref": "#/components/headers/RequestId"
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StartAccountLinkResponse"
                }
              }
            }
          },
          "429": {
            "$ref": "#/components/responses/RateLimited"
          },
          "503": {
            "$ref": "#/components/responses/Unavailable"
          }
        }
      }
    },
    "/v1/account-links/{linkSessionId}/status": {
      "post": {
        "operationId": "getAccountLinkStatus",
        "summary": "Read a private account-link result",
        "description": "Authenticates with the link credential in the bounded JSON body. Once linked, that same secret is accepted as the installation bearer credential.",
        "parameters": [
          {
            "name": "linkSessionId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AccountLinkStatusRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Current link state.",
            "headers": {
              "X-Request-ID": {
                "$ref": "#/components/headers/RequestId"
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AccountLinkStatusResponse"
                }
              }
            }
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "429": {
            "$ref": "#/components/responses/RateLimited"
          }
        }
      }
    },
    "/v1/account-links/{linkSessionId}/callback": {
      "get": {
        "operationId": "completeAccountLink",
        "summary": "Complete the Last.fm browser callback",
        "description": "Validates one-time callback state, atomically associates the newly issued Last.fm web-authorization token with the session, and consumes both for ownership proof.",
        "parameters": [
          {
            "name": "linkSessionId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          },
          {
            "name": "state",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "minLength": 32,
              "maxLength": 512
            }
          },
          {
            "name": "token",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "minLength": 32,
              "maxLength": 512
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Last.fm ownership proof completed.",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "400": {
            "description": "The callback is invalid, expired, rejected, or already consumed.",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "429": {
            "$ref": "#/components/responses/RateLimited"
          }
        }
      }
    },
    "/v1/installations/current/credential": {
      "post": {
        "operationId": "rotateCurrentInstallationCredential",
        "summary": "Rotate the current installation credential",
        "description": "Invalidates the authenticating credential and returns its replacement exactly once.",
        "security": [
          {
            "installationBearer": []
          }
        ],
        "responses": {
          "200": {
            "description": "Credential rotated.",
            "headers": {
              "X-Request-ID": {
                "$ref": "#/components/headers/RequestId"
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/InstallationCredentialResponse"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "409": {
            "$ref": "#/components/responses/Conflict"
          },
          "429": {
            "$ref": "#/components/responses/RateLimited"
          }
        }
      }
    },
    "/v1/installations/current": {
      "delete": {
        "operationId": "revokeCurrentInstallation",
        "summary": "Revoke the current installation",
        "description": "Revokes the authenticating credential. Repeated calls with that credential are unauthorized.",
        "security": [
          {
            "installationBearer": []
          }
        ],
        "responses": {
          "204": {
            "description": "Installation revoked.",
            "headers": {
              "X-Request-ID": {
                "$ref": "#/components/headers/RequestId"
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "429": {
            "$ref": "#/components/responses/RateLimited"
          }
        }
      }
    },
    "/v1/sync": {
      "post": {
        "operationId": "syncPresence",
        "summary": "Refresh installation presence and read cached listening state",
        "description": "Authenticates one installation heartbeat, updates its server-authoritative visibility, and returns cached own-listening and reusable location-presence state. The handler does not perform an unbounded Last.fm request inline.",
        "security": [
          {
            "installationBearer": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SyncRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Heartbeat accepted and cached state returned.",
            "headers": {
              "X-Request-ID": {
                "$ref": "#/components/headers/RequestId"
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SyncResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "409": {
            "$ref": "#/components/responses/Conflict"
          },
          "429": {
            "$ref": "#/components/responses/RateLimited"
          },
          "503": {
            "$ref": "#/components/responses/Unavailable"
          }
        }
      }
    },
    "/v1/relays": {
      "post": {
        "operationId": "createRelay",
        "summary": "Create a Custom Relay",
        "security": [
          {
            "installationBearer": []
